# Core scheduler
TZ=Asia/Shanghai
MARKET_TIMEZONE=Asia/Shanghai
LOG_DIR=logs
LOG_FILE=logs/run.log
PRICE_WINDOW_SIZE=30
QUOTE_SOURCE=qtimg
INDEX_QUOTE_SOURCE=qtimg
QUOTE_SOURCE_POOL=qtimg,eastmoney,sina,akshare
QUOTE_ENRICH_MISSING_FIELDS=true
QUOTE_ENRICH_CACHE_SECONDS=30
QUOTE_ENRICH_MAX_SOURCES=3
DAILY_KLINE_CACHE_SECONDS=300
TRADING_CALENDAR_PROVIDER=auto
REQUEST_MIN_INTERVAL_SECONDS=1.2
REQUEST_JITTER_MAX_SECONDS=0.8
SOURCE_SUCCESS_REWARD=0.05
SOURCE_FAILURE_PENALTY=0.25
SOURCE_MIN_SCORE=0.6
SOURCE_COOLDOWN_SECONDS=900
SOURCE_CIRCUIT_FAILURE_THRESHOLD=3
SOURCE_CIRCUIT_COOLDOWN_SECONDS=900
SOURCE_HEALTH_REPORT_ENABLED=true
SOURCE_HEALTH_REPORT_INTERVAL_MINUTES=60
SOURCE_HEALTH_REPORT_TOPN=8
DAILY_STOCK_ANALYSIS_QUOTE_PATH=data/daily_stock_analysis/latest_quote.json
DAILY_STOCK_ANALYSIS_REPO_PATH=/daily_stock_analysis
DAILY_STOCK_ANALYSIS_BRANCH=main
DAILY_STOCK_ANALYSIS_AUTO_UPGRADE=true
DAILY_STOCK_ANALYSIS_SYNC_MODE=ff_only
DAILY_STOCK_ANALYSIS_AUX_ENABLED=true
DAILY_STOCK_ANALYSIS_MAX_STALENESS_SECONDS=900
DAILY_STOCK_ANALYSIS_ALLOW_STALE=false

# daily_stock_analysis 融合配置
# 方案1: 独立运行 - daily_stock_analysis 生成每日AI选股报告
# 方案2: 数据共享 - stock_monitor 读取 daily_stock_analysis 的行情数据
# 融合模式: 每周一03:00自动检查并同步上游仓库更新
DSA_INTEGRATION_MODE=both
DSA_DATA_SHARE_ENABLED=true
DSA_REPORT_PATH=/daily_stock_analysis/output
BETTAFISH_AUX_ENABLED=true
PYTDX_HOST=119.147.212.81
PYTDX_PORT=7709
GIT_BIN=/usr/bin/git

# Gemini
GEMINI_API_KEY=

# AI provider
AI_PROVIDER=gemini
AI_TIMEOUT_SECONDS=20
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AIHUBMIX_API_KEY=
AIHUBMIX_BASE_URL=https://api.aihubmix.com/v1
AIHUBMIX_MODEL=gpt-4o-mini
MARKET_BRIEF_AI_ENABLED=true

# 东方财富妙想MX_APIKEY (用于OpenClaw Skills，非Python项目直接使用)
# 获取地址: https://dl.dfcfs.com/m/itc4
# 本项目主要使用 qtimg 数据源
MX_APIKEY=your_mx_apikey

# DingTalk notification
DINGDING_WEBHOOK=
DINGDING_SECRET=

# PushDeer notification
PUSHDEER_PUSHKEY=
PUSHDEER_KEY=
PUSHDEER_SERVER=https://api2.pushdeer.com

# Future data source
TUSHARE_TOKEN=
BETTAFISH_REPORT_PATH=data/bettafish/latest_report.json

# Weekly jobs
AUCTION_TOP10_LIMIT=10
AUCTION_TOP10_MIN_AMOUNT=0
AUCTION_CACHE_SECONDS=600
ETF_DECISION_TOPN=3
# 新变量名（与 guardian.py 保持一致），未配置时会回退到 ETF_DECISION_TOPN
ETF_STOCK_ALERT_TOPN=3
ETF_FLOW_DAYS=3
ETF_COMPONENT_FLOW_TOPN=8
ETF_SUPPORT_LOOKBACK_DAYS=30
ETF_SUPPORT_MAX_DISTANCE_BUY=3.0
ETF_SUPPORT_MAX_DISTANCE_CHASE=6.0
ETF_HOLDCAP_404_COOLDOWN_SECONDS=21600
ETF_HOLDINGS_DIFF_MIN_PCT=0.02
ETF_HOLDINGS_NEW_MIN_PCT=0.50
ETF_STATE_BUY_SCORE=70
ETF_STATE_WATCH_SCORE=50
ETF_STATE_AVOID_CHASE_PCT=4.0
NOON_RECAP_TIME=11:35
CLOSE_RECAP_TIME=15:10
WEEKLY_VERSION_CHECK_TIME=03:00
MONDAY_NEWS_PUSH_TIME=08:30
FINANCE_NEWS_RSS_URLS=https://www.zhitongcaijing.com/content/detail/391.html,https://www.yicai.com/news/,https://finance.sina.com.cn/stock/
FINANCE_NEWS_JSON_URLS=https://newsapi.org/v2/top-headlines?country=cn&apiKey=demo
POLICY_NEWS_JSON_URLS=
NEWS_REQUIRE_CHINESE=true
NEWS_REQUIRE_A_SHARE=true
NEWS_RELAX_TO_CN_ONLY=true
NEWS_MAX_AGE_DAYS=3
NEWS_HEADLINE_LIMIT=8
WEEKLY_STATE_FILE=logs/weekly_ops_state.json

# Scheduler (APScheduler)
SCHEDULER_DB_PATH=logs/apscheduler.sqlite
SCHEDULER_MISFIRE_GRACE_SECONDS=120
SCHEDULER_MAX_INSTANCES=1
SCHEDULER_COALESCE=true

# Notification guard
NOTIFY_COOLDOWN_SECONDS=300
NOTIFY_DEDUPE_SECONDS=1800
NOTIFY_STATE_FILE=logs/notify_state.json
TURNOVER_RATE_ALERT_THRESHOLD=5.0
TURNOVER_ALERT_ENABLED=false
TURNOVER_ALERT_MODE=assist
TURNOVER_ENTRY_MIN=5.0
TURNOVER_MIN_FILTER=3.0
TURNOVER_HOT_MIN=5.0
TURNOVER_RISK_MAX=20.0
DEVIATION_MAX=5.0
VOLUME_RATIO_MIN=1.5
FLOW_STREAK_MIN=3
FLOW_STREAK_MAX=5
PCT_CHANGE_ALERT_THRESHOLD=2.0
DEFAULT_STOP_LOSS_PCT=0.03
DEFAULT_TARGET_PCT=0.05
HOT_SECTOR_MIN_STOCKS=5
HOT_SECTOR_MIN_PCT=2.0
HOT_SECTOR_SCAN_LIMIT=12
RECAP_SECTOR_TOPN=10
MARKET_BREADTH_SAMPLE_SIZE=5000
MARKET_BREADTH_MIN_SAMPLE=800
MARKET_PAGE_SIZE=500
MARKET_MAX_PAGES=20
MARKET_ACTIVE_TOPN=10
MARKET_CONTEXT_SAMPLE_SIZE=5000
MARKET_CONTEXT_PAGE_SIZE=200
MARKET_CONTEXT_MIN_SAMPLE=800
MARKET_CONTEXT_MODEL=percentile

# Multi-factor scoring (BigQuant-style)
FACTOR_SCORING_ENABLED=true
FACTOR_MIN_SCORE=60
FACTOR_CACHE_SECONDS=300

# Factor weights (must sum to 1.0)
FACTOR_WEIGHT_PE=0.15
FACTOR_WEIGHT_PB=0.10
FACTOR_WEIGHT_TURNOVER=0.20
FACTOR_WEIGHT_FUND_FLOW=0.25
FACTOR_WEIGHT_MOMENTUM=0.30

# Fund flow
FUND_FLOW_CACHE_SECONDS=300

# Famous trader / Dragon Tiger List
FAMOUS_TRADER_ENABLED=true

# Intraday scan
SCAN_MIN_PCT_CHANGE=3.0
SCAN_MAX_PCT_CHANGE=9.5
SCAN_MIN_TURNOVER_RATE=3.0
SCAN_MIN_SCORE=45
SCAN_ADAPTIVE_ENABLED=true
SCAN_RELAX_SECTOR_THRESHOLD=4
SCAN_RELAX_MIN_PCT_CHANGE=1.2
SCAN_RELAX_MIN_TURNOVER_RATE=1.8
SCAN_RELAX_MIN_SCORE=38
SCAN_MAX_EVAL_ROWS=24
INTRADAY_CANDIDATE_TOPN=10
INTRADAY_SCAN_UNIVERSE=180
INTRADAY_USE_FUND_FLOW=false

# A段 起爆资金（3秒双快照）
BURST_CANDIDATE_TOPN=10
BURST_SCAN_UNIVERSE=300
BURST_SCAN_INTERVAL_SECONDS=3
BURST_MIN_3S_PCT_CHANGE=0.4
BURST_MIN_3S_AMOUNT=6000000
BURST_MIN_PCT_CHANGE=2.0
BURST_MAX_PCT_CHANGE=7.5

# B段 小盘股监控
SMALL_CAP_TOPN=10
SMALL_CAP_SCAN_UNIVERSE=300
SMALL_CAP_MIN_MV_YI=30
SMALL_CAP_MAX_MV_YI=300
SMALL_CAP_MIN_PCT_CHANGE=1.5
SMALL_CAP_MAX_PCT_CHANGE=9.5
SMALL_CAP_MIN_TURNOVER_RATE=3.0
SMALL_CAP_MIN_AMOUNT_WAN=3000
